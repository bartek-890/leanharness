{
  "name": "leanharness",
  "version": "0.5.0",
  "description": "Minimal agent harness starter for Claude Code — 10 files, each one a published rule. Lean CLAUDE.md, verifiable definition-of-done, read-only explorer/code-reviewer/researcher subagents, pre-ship security audit, safe permission defaults.",
  "keywords": [
    "claude-code",
    "claude",
    "agents",
    "harness",
    "claude-md",
    "agents-md",
    "context-engineering",
    "scaffold"
  ],
  "license": "MIT",
  "author": "Bartłomiej Krupa (https://bartlomiejkrupa.dev)",
  "homepage": "https://github.com/bartek-890/leanharness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartek-890/leanharness.git"
  },
  "bugs": "https://github.com/bartek-890/leanharness/issues",
  "type": "module",
  "bin": {
    "leanharness": "bin/cli.js"
  },
  "scripts": {
    "bench:static": "node bench/static.mjs",
    "bench:score": "node bench/score.mjs --fixtures",
    "bench:run": "node bench/run.mjs",
    "bench": "node bench/static.mjs && node bench/score.mjs --fixtures"
  },
  "files": [
    "bin",
    "template"
  ],
  "engines": {
    "node": ">=18"
  }
}
